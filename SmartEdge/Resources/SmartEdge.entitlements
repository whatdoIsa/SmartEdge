<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Disable App Sandbox for system-level access -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    
    <!-- Allow Apple Events for media control -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    
    <!-- Allow calendar access -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
    
    <!-- Allow Bluetooth access -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>
    
    <!-- Allow file system access -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    
    <!-- Allow network access -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow the bundled mediaremote-adapter helper to load its framework.
         /usr/bin/perl inherits the parent's hardening when spawned as a
         child; without this key the perl child silently fails to dlopen
         MediaRemoteAdapter.framework because its code signature doesn't
         match SmartEdge's. The helper output never reaches stdout, so
         the notch sees no playback data. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>